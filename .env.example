# ============================================================
# Aaj Kya Banega? — Firebase Configuration
# ============================================================
# 1. Go to https://console.firebase.google.com/
# 2. Create a new project called "Aaj Kya Banega"
# 3. Add a Web App to the project
# 4. Copy the config values below from "Project Settings > Your apps"
# 5. Rename this file to `.env.local` and fill in the values
# ============================================================

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Cloud Messaging VAPID Key
# Go to: Project Settings > Cloud Messaging > Web Push certificates > Generate key pair
VITE_FIREBASE_VAPID_KEY=your-vapid-key-here

# App Deep Link Base URL (update after deploying)
# Example: https://aajkyabanega.app or your Firebase Hosting URL
VITE_APP_BASE_URL=http://localhost:5173
